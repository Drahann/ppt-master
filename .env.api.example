PPT_API_HOST=0.0.0.0
PPT_API_PORT=3000
PPT_API_PROJECT_BASE_DIR=/app/projects
PPT_API_JOBS_DIR=/app/tmp/api-jobs
PPT_API_MAX_CONCURRENT_JOBS=15
PPT_API_ASYNC_WORKERS=15
PPT_API_RUNNER_TIMEOUT_SECONDS=7200
PPT_API_CANVAS_FORMAT=ppt169
PPT_API_KEEP_JOB_FILES=1
PPT_API_DEFAULT_RESPONSE_MODE=sync
PPT_API_DEFAULT_CALLBACK_MODE=auto
PPT_API_METRICS_EXPORT_ENABLED=1
PPT_API_METRICS_EXPORT_DIR=/app/projects/metrics
PPT_API_METRICS_EXPORT_INTERVAL_SECONDS=10
PPT_API_METRICS_EXPORT_RETENTION_FILES=2000
PPT_API_BATCH_MODE=parallel
PPT_API_BATCH_SIZE=6
PPT_API_PARALLEL_BATCH_WORKERS=3
PPT_API_BATCH_PARTITION=fixed
PPT_API_SVG_ANCHOR_FIRST=0
PPT_API_LLM_SPEC_SLOTS=4
PPT_API_LLM_SVG_SLOTS=10
PPT_API_LLM_NOTES_SLOTS=8
PPT_API_POSTPROCESS_SLOTS=4
PPT_API_SVG_FAIR_SHARE=1
PPT_API_SVG_FAIR_SHARE_DELAY_SECONDS=8
PPT_API_SVG_STAGE_STAGGER_SECONDS=0
PPT_API_SVG_BATCH_STAGGER_SECONDS=0
REDIS_URL=redis://redis:6379/0
PPT_REDIS_KEY_PREFIX=ppt
PPT_API_LLM_BUDGET_TPM=0
PPT_API_LLM_TARGET_UTILIZATION=0.75
PPT_API_LLM_MIN_SVG_CONCURRENCY=1
PPT_API_LLM_HARD_MAX_SVG_CONCURRENCY=18
PPT_API_LLM_EWMA_ALPHA=0.2
PPT_API_LLM_TPM_PACING_ENABLED=1
PPT_API_LLM_PACING_WINDOW_SECONDS=60
PPT_API_LLM_PACING_SAFETY_FACTOR=1.15
PPT_API_LLM_DEFAULT_SVG_RESERVE_TOKENS=700000
PPT_API_LIVE_USAGE_ENABLED=1
PPT_API_LIVE_USAGE_ALL_STAGES=1
PPT_API_LIVE_USAGE_POLL_SECONDS=10
PPT_API_LIVE_USAGE_LOG_INTERVAL_SECONDS=60
PPT_API_LIVE_TPM_WINDOW_SECONDS=60
PPT_API_LIVE_TPM_ADMISSION_ENABLED=1
PPT_API_SVG_LIVE_TPM_BYPASS_COMPLETION_GUARD=1
PPT_API_SVG_LIVE_TPM_STARTUP_RESERVE_SECONDS=15
PPT_API_QWEN_GLOBAL_START_STAGGER_ENABLED=1
PPT_API_QWEN_GLOBAL_START_STAGGER_ALL_STAGES=1
PPT_API_SPEC_QWEN_START_STAGGER_SECONDS=4
PPT_API_NOTES_QWEN_START_STAGGER_SECONDS=2
PPT_API_SVG_QWEN_START_STAGGER_SECONDS=3
PPT_API_SVG_START_JITTER_SECONDS=5
PPT_API_QWEN_START_STAGGER_PER_STAGE=1
PPT_API_SVG_QWEN_REPAIR_TURN_BACKOFF_SECONDS=5
PPT_API_NOTES_QWEN_REPAIR_TURN_BACKOFF_SECONDS=3
PPT_API_QWEN_SVG_BATCH_TURN_TIMEOUT_SECONDS=1800
PPT_API_SVG_SCHEDULER_HEARTBEAT_SECONDS=120
PPT_API_SVG_SCHEDULER_RUNNING_STALE_SECONDS=1800
PPT_API_SVG_BATCH_WORKER_TIMEOUT_SECONDS=7200

# Optional: override runner models
PPT_API_QWEN_MODEL=qwen3.6-plus
PPT_API_QWEN_SPEC_MODEL=qwen3.6-plus
PPT_API_QWEN_SPEC_MAX_TOKENS=65536
PPT_API_QWEN_REVIEW_MODEL=qwen3.6-plus
PPT_API_QWEN_NOTES_MODEL=qwen3.6-plus

# Optional: force qwen CLI/direct stages to use a new OpenAI-compatible API instead of local qwen auth files
# If you enable this, the runner will pass these flags to `qwen` and direct API stages:
#   --auth-type openai
#   --openai-api-key
#   --openai-base-url
PPT_API_QWEN_AUTH_TYPE=
PPT_API_QWEN_API_KEY=
PPT_API_QWEN_BASE_URL=

# Optional: Redis-backed global Qwen account pool for centralized SVG workers.
# Prefer mounting one shared JSON file with the same six accounts on every API server.
# If unset, the runner falls back to PPT_API_QWEN_API_KEY/PPT_API_QWEN_BASE_URL.
PPT_SERVER_ID=server-1
PPT_API_QWEN_ACCOUNT_POOL_FILE=
PPT_API_QWEN_ACCOUNT_POOL_JSON=
PPT_API_QWEN_ACCOUNT_POOL_WINDOW_SECONDS=60
PPT_API_QWEN_ACCOUNT_LEASE_TTL_SECONDS=3600
PPT_API_QWEN_ACCOUNT_RATE_LIMIT_COOLDOWN_SECONDS=60
PPT_API_QWEN_ACCOUNT_TRANSIENT_COOLDOWN_SECONDS=30
PPT_API_QWEN_ACCOUNT_POOL_MAX_RETRIES=2
PPT_API_QWEN_ACCOUNT_POOL_RECORD_RELEASE_USAGE=0
PPT_API_QWEN_ACCOUNT_POOL_WAIT_TIMEOUT_SECONDS=7200
PPT_API_QWEN_ACCOUNT_POOL_RETRY_SECONDS=2

# COS upload target
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_REGION=ap-shanghai
COS_BUCKET=your-cos-bucket

# Old-service-compatible callback
REPORT_CALLBACK_URL=https://example.com/api/report/receiveReport
