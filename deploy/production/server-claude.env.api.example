PPT_API_HOST=0.0.0.0
PPT_API_PORT=3000
PPT_API_HOST_PORT=3003
PPT_API_PROJECT_BASE_DIR=/app/projects
PPT_API_JOBS_DIR=/app/tmp/api-jobs
PPT_API_KEEP_JOB_FILES=1
PPT_API_MAX_CONCURRENT_JOBS=20
PPT_API_ASYNC_WORKERS=20
PPT_API_RUNNER_TIMEOUT_SECONDS=7200
PPT_API_DEFAULT_RESPONSE_MODE=sync
PPT_API_DEFAULT_CALLBACK_MODE=auto
PPT_API_METRICS_EXPORT_ENABLED=1
PPT_API_METRICS_EXPORT_DIR=/app/projects/metrics
PPT_API_METRICS_EXPORT_INTERVAL_SECONDS=30

PPT_REDIS_URL=redis://:change-me@host.docker.internal:6380/0
PPT_REDIS_KEY_PREFIX=ppt-claude

PPT_API_CANVAS_FORMAT=ppt169
PPT_API_STYLE=general
PPT_API_RENDERER=claude
PPT_API_PLANNER_PROVIDER=qwen
PPT_API_NOTES_PROVIDER=qwen
PPT_API_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PPT_API_QWEN_MODEL=qwen3.6-plus
PPT_API_QWEN_API_KEY=sk-dashscope-key
DASHSCOPE_API_KEY=sk-dashscope-key
QWEN_API_KEY=sk-dashscope-key
PPT_API_QWEN_MAX_TOKENS=65536
PPT_API_QWEN_TIMEOUT=900

PPT_API_DEEPSEEK_ACCOUNT_POOL_FILE=/app/secrets/deepseek_claude_account_pool.json
PPT_API_REQUIRE_ACCOUNT_POOL=1
PPT_API_ACCOUNT_LEASE_TIMEOUT_SECONDS=7200
PPT_API_DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
PPT_API_DEEPSEEK_MODEL=deepseek-v4-pro
PPT_API_CLAUDE_MODEL=deepseek-v4-pro[1m]
PPT_API_CLAUDE_FLASH_MODEL=deepseek-v4-flash
PPT_API_CLAUDE_EFFORT=max
PPT_API_CLAUDE_TIMEOUT=1200
PPT_API_CLAUDE_RETRIES=1
PPT_API_SVG_WORKERS=12
PPT_API_SVG_BATCH_SIZE=3
PPT_API_CACHE_PRIME=1
PPT_API_RUNNER_START_STAGGER_ENABLED=1
PPT_API_RUNNER_START_STAGGER_SECONDS=4
PPT_API_RUNNER_START_JITTER_SECONDS=12
PPT_API_RUNNER_START_STAGGER_SCOPE=global
PPT_MASTER_CLAUDE_CONFIG_ROOT=/app/tmp/claude-code-config
PPT_MASTER_CLAUDE_CONFIG_SCOPE=job
PPT_MASTER_CLAUDE_LOCK_RETRIES=5

COS_SECRET_ID=replace-me
COS_SECRET_KEY=replace-me
COS_REGION=ap-shanghai
COS_BUCKET=replace-me

REPORT_CALLBACK_URL=https://example.com/api/report/receiveReport
